// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "struckout-mcu-esp",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"USER_UID": "1000",
			"USER_GID": "1000"
		}
	},
	"runArgs": [
		"--name",
		"struckout-mcu-devcontainer",
		"--device=/dev/struckout_mcu_esp:/dev/ttyACM0",
		"--device-cgroup-rule=c 189:* rwm"
	],
	"containerEnv": {
		"TZ": "Asia/Tokyo"
	},
	"mounts": [
		"type=bind,source=/dev/bus/usb/,target=/dev/bus/usb/",
		"type=bind,source=/home/taichi765/source/git_clones/trouble/,target=/workspaces/git_clones/trouble/,consistency=cached",
		"type=volume,source=cargo-cache,target=/home/vscode/.cargo/"
	],
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"tamasfe.even-better-toml",
				"rust-lang.rust-analyzer",
				"probe-rs.probe-rs-debugger"
			]
		}
	}
}