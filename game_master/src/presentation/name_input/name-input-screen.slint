
import { Icons } from "../icons.slint";
enum KeyBoardMode { Hiragana, Katakana }

global Adopter {
    in property <string> player-name-text;
    in property <KeyBoardMode> keyboard-mode;
    in property <string> error-msg;
    callback switch-keyboard-mode();
    callback push-character(char: string);
    callback remove-character();
    callback submit-name();
}

component KeyButton {
    in property <string> text;
    callback clicked();

    Rectangle {
        border-color: black;
        border-width: 4px;

        Text {
            text: text;
        }

        touch := TouchArea {
            clicked => {
                root.clicked();
            }
        }
    }
}

