component KeyboardBottomBar inherits Rectangle {
    callback switch-keyboard-mode();
    callback click-backspace();
    callback submit-name();

    HorizontalLayout {
        Rectangle {
            Text {
                text: "あア";
            }

            touch1 := TouchArea {
                clicked => {
                    root.switch-keyboard-mode();
                }
            }
        }

        Rectangle {
            Image {
                source: Icons.backspace;
            }

            touch2 := TouchArea {
                clicked => {
                    root.click-backspace();
                }
            }
        }

        Rectangle {
            Image {
                source: Icons.arrow-forward;
            }

            touch3 := TouchArea {
                clicked => {
                    root.submit-name();
                }
            }
        }
    }
}

export component NameInputScreen inherits Rectangle {

    VerticalLayout {
        alignment: LayoutAlignment.stretch;

        Rectangle {
            border-color: black;
            border-width: 4px;

            Text {
                text: Adopter.player-name-text;
            }
        }

        if Adopter.error-msg != "": Rectangle {
            Text {
                text: Adopter.error-msg;
                color: red;
            }
        }

        KeyboardBody {
            spacing: 4px;
            mode: Adopter.keyboard-mode;

            text-added(text) => {
                Adopter.push-character(text);
            }
        }

        KeyboardBottomBar {
            switch-keyboard-mode => {
                Adopter.switch-keyboard-mode();
            }

            click-backspace => {
                Adopter.remove-character();
            }

            submit-name => {
                Adopter.submit-name();
            }
        }
    }
}

export { Adopter as NameInputAdopter }
