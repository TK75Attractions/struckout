import { AboutSlint, VerticalBox } from "std-widgets.slint";
import { TopBar } from "top-bar.slint";
import { StartScreen } from "./start/start-screen.slint";
import {
    NameInputScreen,
} from "./name_input/name-input-screen.slint";
import {
    DifficulitySelectScreen,
} from "./difficulity_select/difficulity-select-screen.slint";
import { PlayingScreen } from "./playing/playing-screen.slint";
import { ScoreScreen } from "./score/score-screen.slint";
import { RankingScreen } from "./ranking/ranking-screen.slint";
import { FallbackScreen } from "fallback/fallback-screen.slint";
import {
    ConnectionFailedScreen,
} from "connection_failed/connection-failed-screen.slint";
import { ConnectingScreen } from "connecting/connecting-screen.slint";

export {
    StartAdopter,
}from "./start//start-screen.slint";
export {
    NameInputAdopter,
}from "./name_input/name-input-screen.slint";
export {
    DifficulitySelectAdopter,
}from "./difficulity_select/difficulity-select-screen.slint";
export { FallbackAdopter }from "./fallback/fallback-screen.slint";
export {
    ConnectionFailedAdopter,
}from "./connection_failed/connection-failed-screen.slint";
export { PlayingAdopter }from "./playing/playing-screen.slint";
export { ScoreAdopter }from "./score/score-screen.slint";
export { RankingAdopter }from "./ranking/ranking-screen.slint";
export { ConnectingAdopter }from "./connecting/connecting-screen.slint";


enum UiNavRoute {
    Start,
    NameInput,
    DifficulitySelect,
    Playing,
    Score,
    Ranking,
    Fallback,
    ConnectionFailed,
    Connecting,
}

export component AppWindow inherits Window {
    full-screen: false;

    in property <UiNavRoute> nav-route;

    VerticalLayout {
        top-bar := TopBar { }

        if nav-route == UiNavRoute.Start: StartScreen { }
        if nav-route == UiNavRoute.NameInput: NameInputScreen { }
        if nav-route == UiNavRoute.DifficulitySelect:DifficulitySelectScreen { }
        if nav-route == UiNavRoute.Playing: PlayingScreen { }
        if nav-route == UiNavRoute.Score: ScoreScreen { }
        if nav-route == UiNavRoute.Ranking: RankingScreen { }
        if nav-route == UiNavRoute.Fallback: FallbackScreen { }
        if nav-route == UiNavRoute.ConnectionFailed: ConnectionFailedScreen { }
        if nav-route == UiNavRoute.Connecting: ConnectingScreen { }
    }
}
