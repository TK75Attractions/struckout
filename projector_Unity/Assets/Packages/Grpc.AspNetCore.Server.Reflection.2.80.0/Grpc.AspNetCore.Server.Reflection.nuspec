<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Grpc.AspNetCore.Server.Reflection</id>
    <version>2.80.0</version>
    <authors>The gRPC Authors</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <icon>packageIcon.png</icon>
    <projectUrl>https://github.com/grpc/grpc-dotnet</projectUrl>
    <description>Automatic discovery of services for Grpc.Reflection</description>
    <copyright>Copyright 2019 The gRPC Authors</copyright>
    <tags>gRPC RPC HTTP/2</tags>
    <repository type="git" url="https://github.com/grpc/grpc-dotnet.git" commit="f22747c72676120b2bc69a1ba7c8bed995e29b1b" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Grpc.AspNetCore.Server" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Grpc.Reflection" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Google.Protobuf" version="3.31.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Grpc.AspNetCore.Server" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Grpc.Reflection" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Google.Protobuf" version="3.31.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="Grpc.AspNetCore.Server" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Grpc.Reflection" version="2.80.0" exclude="Build,Analyzers" />
        <dependency id="Google.Protobuf" version="3.31.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net8.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
      <group targetFramework="net9.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
      <group targetFramework="net10.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
    </frameworkReferences>
  </metadata>
</package>